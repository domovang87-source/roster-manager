NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
OPENAI_API_KEY=

# Optional: playbook-style RAG for drafts (requires Supabase search_knowledge + knowledge_base — see supabase/playbook-rag-migration.sql). Set to 0 to disable.
# STACK_PLAYBOOK_RAG=0

# Stripe (Dashboard → Products → each price → Price ID = price_...)
STRIPE_SECRET_KEY=
# Pro
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_YEARLY=
# Optional legacy alias for Pro monthly
# STRIPE_PRICE_ID=

# Elite (monthly: set STRIPE_PRICE_ID_ELITE_MONTHLY or a single STRIPE_PRICE_ID_ELITE for monthly)
STRIPE_PRICE_ID_ELITE_MONTHLY=
STRIPE_PRICE_ID_ELITE_YEARLY=
# STRIPE_PRICE_ID_ELITE=

# Server-only: SMS / automation → POST /api/incoming-message (Bearer). Leave unset to disable the route.
# STACK_INCOMING_WEBHOOK_SECRET=

# Vercel Cron weekly audit already uses CRON_SECRET. Same secret gates POST /api/approve-all (bulk mark drafts sent).
# CRON_SECRET=

# Public site URL for Stripe return URLs only (never use browser Origin). Example: https://getstack.so
# NEXT_PUBLIC_APP_URL=

# Service role (webhooks, cron) — never expose to the client
# SUPABASE_SERVICE_ROLE_KEY=
# STRIPE_WEBHOOK_SECRET=
